generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String @id @default(uuid())
  email     String @unique
  password  String
  roles     UserRole[]
}

model Role {
  id           String @id @default(uuid())
  name         String @unique
  permissions  Permission[]
  users        UserRole[]
}

model Permission {
  id     String @id @default(uuid())
  name   String @unique
  roles  Role[]
}

model UserRole {
  userId String
  roleId String

  user User @relation(fields: [userId], references: [id])
  role Role @relation(fields: [roleId], references: [id])

  @@id([userId, roleId])
}
